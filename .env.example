# ── Database ──────────────────────────────────────────────────────────────────
# Set POSTGRES_PASSWORD to a strong random value and use it in DATABASE_URL too.
# Generate a good password: openssl rand -hex 24
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Must match POSTGRES_PASSWORD above
DATABASE_URL=postgresql://chorequest:REPLACE_WITH_STRONG_PASSWORD@db:5432/chorequest

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3002

# Session encryption key — must be at least 32 characters.
# Generate one: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at resend.com, verify your domain, then paste your API key here.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must match a verified Resend sender domain, e.g. noreply@mail.yourdomain.com
FROM_EMAIL=noreply@mail.yourdomain.com

# ── Game settings ─────────────────────────────────────────────────────────────
DEFAULT_THEME=zombie-survival
ALLOWANCE_POINTS_PER_DOLLAR=100
XP_PER_POINT=5
GAME_CURRENCY_PER_POINT=2

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
